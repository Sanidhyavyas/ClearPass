DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=clearpass
DB_PORT=3306

# ── Logging ──────────────────────────────────────────────────────────────
# Levels: error | warn | info | debug
LOG_LEVEL=info

# Timestamp format tokens: YYYY MM DD HH mm ss
LOG_TIME_FORMAT=YYYY-MM-DD HH:mm:ss

# Environment (production=JSON logs, development=pretty logs)
NODE_ENV=development
PORT=5000
JWT_SECRET=replace_with_a_long_random_secret
CLIENT_URL=http://localhost:3000

# SMTP — Gmail example (use App Password if 2FA is on)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Mailtrap example (for testing)
# SMTP_HOST=sandbox.smtp.mailtrap.io
# SMTP_PORT=2525
# SMTP_USER=mailtrap_username
# SMTP_PASS=mailtrap_password
