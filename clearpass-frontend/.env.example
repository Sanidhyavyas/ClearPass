# ── API ──────────────────────────────────────────────────────────────────
REACT_APP_API_URL=https://clearpass-backend.onrender.com

# ── Logging ──────────────────────────────────────────────────────────────
# Levels: error | warn | info | debug
# Production default is "warn" (only warnings + errors logged & shipped)
REACT_APP_LOG_LEVEL=warn

# Must match backend LOG_TIME_FORMAT so timestamps are comparable
REACT_APP_LOG_TIME_FORMAT=YYYY-MM-DD HH:mm:ss
